# --- Servidor ---
PORT=4000

# --- MongoDB Atlas ---
# Pega aquí tu cadena de conexión de Atlas (Database > Connect > Drivers).
# Ejemplo: mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/ehs_platform?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/ehs_platform?retryWrites=true&w=majority

# --- Seguridad ---
JWT_SECRET=cambia_este_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# --- Seed inicial (se crean si la base está vacía) ---
SEED_ON_START=true
SEED_ADMIN_EMAIL=admin@ehs.local
SEED_ADMIN_PASSWORD=Admin123*
